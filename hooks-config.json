{
	"_comment": "Team default hook configuration. Personal overrides go in hooks-config.local.json (git-ignored).",
	"audio": {
		"enabled": false,
		"volume": 0.5,
		"events": {
			"session_start": true,
			"commit": true,
			"error": true,
			"task_complete": true,
			"safety_block": true,
			"compact": true,
			"gate_nogo": true
		}
	},
	"claude_md_monitor": {
		"enabled": true,
		"warn_lines": 150,
		"critical_lines": 300
	},
	"compact_reminder": {
		"enabled": true
	}
}
