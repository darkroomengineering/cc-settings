{
  "$id": "https://cc-settings.darkroom/schema/settings.json",
  "title": "Claude Code settings.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "env": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "model": {
      "type": "string"
    },
    "spinnerVerbs": {
