                      "model": {
                        "type": "string"
                      },
                      "if": {
                        "type": "string"
                      },
                      "timeout": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 9007199254740991
                      },
                      "async": {
                        "type": "boolean"
                      },
                      "statusMessage": {
                        "type": "string"
                      },
                      "once": {
                        "type": "boolean"
                      }
                    },
                    "required": [
                      "type",
