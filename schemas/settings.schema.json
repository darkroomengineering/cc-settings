              "_comment": {
                "type": "string"
              },
              "_description": {
                "type": "string"
              },
              "_usage": {
                "type": "string"
              },
              "_contextCost": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high"
                ]
