{
  "$id": "https://cc-settings.darkroom/schema/claude-json.json",
  "title": "~/.claude.json (passthrough)",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "mcpServers": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "http"
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "headers": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "string"
                }
              },
              "_comment": {
                "type": "string"
              },
              "_description": {
                "type": "string"
              },
              "_usage": {
                "type": "string"
              },
              "_contextCost": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high"
                ]
              },
              "_status": {
                "type": "string",
                "enum": [
                  "installed",
                  "optional"
                ]
              },
              "serverInstructions": {
                "type": "string"
              }
            },
            "required": [
              "type",
              "url"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "stdio"
              },
              "command": {
                "type": "string",
                "minLength": 1
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "env": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "string"
                }
              },
              "_comment": {
                "type": "string"
              },
              "_description": {
                "type": "string"
              },
              "_usage": {
                "type": "string"
              },
              "_contextCost": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high"
                ]
              },
              "_status": {
                "type": "string",
                "enum": [
                  "installed",
                  "optional"
                ]
              },
              "serverInstructions": {
                "type": "string"
              }
            },
            "required": [
              "command"
            ],
            "additionalProperties": false
          }
        ]
      }
    },
    "firstStartTime": {
      "type": "string"
    },
    "numStartups": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "installMethod": {
      "type": "string"
    },
    "autoUpdates": {
      "type": "boolean"
    }
  },
  "additionalProperties": {}
}
