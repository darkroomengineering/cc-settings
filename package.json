{
  "name": "cc-settings",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.1.30"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:safety-net": "bun test tests/safety-net.test.ts",
    "bench:baseline": "bun bench/run-baseline.ts",
    "prototype:compile": "bun bench/prototype/compile.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "schemas:emit": "bun src/schemas/emit.ts",
    "upstream:scan": "bun src/upstream/scan.ts"
  },
  "dependencies": {
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/bun": "1.3.12",
    "typescript": "6.0.3"
  }
}
