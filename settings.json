{
	"$schema": "./schemas/settings.schema.json",
	"env": {
		"CLAUDE_CODE_EFFORT_LEVEL": "high",
		"CLAUDE_CODE_SUBPROCESS_ENV_SCRUB": "1",
		"CLAUDE_CODE_NO_FLICKER": "1",
		"ENABLE_PROMPT_CACHING_1H": "1",
		"CC_CLAUDE_MD_MONITOR_ENABLED": "true",
		"CC_CLAUDE_MD_WARN_LINES": "400",
		"CC_CLAUDE_MD_CRITICAL_LINES": "600"
	},
	"model": "opus[1m]",
	"showThinkingSummaries": true,
	"teammateMode": "auto",
	"includeGitInstructions": false,
	"attribution": {
		"commit": "",
		"pr": ""
	},
	"plansDirectory": "./plans",
	"spinnerVerbs": {
		"mode": "replace",
		"verbs": [
			"Analyzing",
			"Architecting",
			"Building",
			"Checking",
			"Composing",
			"Crafting",
			"Debugging",
			"Deploying",
			"Designing",
			"Evaluating",
			"Exploring",
			"Implementing",
			"Investigating",
			"Optimizing",
			"Orchestrating",
			"Refactoring",
			"Researching",
			"Reviewing",
			"Scaffolding",
			"Testing",
			"Tracing",
			"Validating",
			"Wiring"
		]
	},
	"statusLine": {
		"type": "command",
		"command": "bun \"$HOME/.claude/src/hooks/statusline.ts\"",
		"refreshInterval": 30
	},
	"mcpServers": {
		"context7": {
			"command": "npx",
			"args": [
				"-y",
				"@upstash/context7-mcp"
			],
			"_comment": "Library documentation lookup. Auto-triggered by /docs skill and documentation-related prompts.",
			"serverInstructions": "Library and framework documentation lookup, API references, usage examples, and best practices. Use for questions about external libraries, SDKs, HTTP APIs, or how to use specific functions, components, or configuration options."
		},
		"Sanity": {
			"type": "http",
			"url": "https://mcp.sanity.io",
			"_comment": "Sanity CMS operations. Requires OAuth auth on first use. See: sanity.io/docs/compute-and-ai/mcp-server",
			"serverInstructions": "Sanity CMS content and configuration operations including querying datasets, inspecting schemas, and managing content documents. Use for any tasks involving Sanity projects, GROQ queries, or CMS-driven content workflows."
		},
		"tldr": {
			"command": "tldr-mcp",
			"args": [
				"--project",
				"."
			],
			"_comment": "Requires: pipx install llm-tldr (v1.5+). Run 'tldr warm .' in project to index.",
			"serverInstructions": "Semantic codebase analysis and repository-level search over the current project. 17 languages auto-detected. Use when you need to find where something is implemented, understand large or unfamiliar code, trace call graphs, or answer questions that require scanning many files across the codebase. Do not hardcode the language parameter — auto-detection is preferred."
		},
		"figma": {
			"type": "http",
			"url": "https://mcp.figma.com/mcp",
			"_comment": "Figma Dev Mode MCP (remote). Requires Dev or Full seat. OAuth on first use.",
			"serverInstructions": "Figma design inspection and extraction: tokens, styles, component props, variables, and file structure. Use for design-to-code workflows, design fidelity checks, and extracting design tokens. Prefer this over screenshot-based workflows when structured design data is needed."
		},
		"chrome-devtools": {
			"command": "npx",
			"args": [
				"-y",
				"chrome-devtools-mcp@latest"
			],
			"_comment": "Chrome DevTools via CDP. Performance traces, network, console, user simulation.",
			"serverInstructions": "Chrome DevTools control for performance tracing, network inspection, console logs, DOM inspection, user interaction simulation, and performance audits. Prefer this over shelling out to the lighthouse CLI when measuring Core Web Vitals."
		}
	},
	"permissions": {
		"allow": [
			"Bash(bun:*)",
			"Bash(bunx:*)",
			"Bash(npm run:*)",
			"Bash(git status:*)",
			"Bash(git diff:*)",
			"Bash(git log:*)",
			"Bash(git show:*)",
			"Bash(git branch:*)",
			"Bash(git add:*)",
			"Bash(git commit:*)",
			"Bash(git checkout:*)",
			"Bash(git stash:*)",
			"Bash(git push:*)",
			"Bash(git blame:*)",
			"Bash(git rev-parse:*)",
			"Bash(git remote:*)",
			"Bash(gh:*)",
			"Bash(biome:*)",
			"Bash(vitest:*)",
			"Bash(pinchtab:*)",
			"Bash(lighthouse:*)",
			"Bash(open -a:*)",
			"Bash(ls:*)",
			"Bash(pwd:*)",
			"Bash(tree:*)",
			"Bash(wc:*)",
			"Bash(file:*)",
			"Bash(stat:*)",
			"Bash(which:*)",
			"Bash(type:*)",
			"Bash(echo:*)",
			"Bash(grep:*)",
			"Bash(rg:*)",
			"Bash(find:*)",
			"Bash(diff:*)",
			"Bash(sort:*)",
			"Bash(uniq:*)",
			"Bash(cut:*)",
			"Bash(awk:*)",
			"Bash(jq:*)",
			"Bash(xargs:*)",
			"Bash(du:*)",
			"Bash(df:*)",
			"Bash(env:*)",
			"Bash(printenv:*)",
			"Bash(date:*)",
			"Bash(uname:*)",
			"Bash(whoami:*)",
			"Bash(basename:*)",
			"Bash(dirname:*)",
			"Bash(realpath:*)",
			"Bash(node -e:*)",
			"Bash(node -p:*)",
			"Bash(mkdir:*)",
			"Bash(cp:*)",
			"Bash(mv:*)",
			"Bash(rm -rf node_modules)",
			"Bash(rm -rf .next)",
			"Bash(rm -rf dist)",
			"Bash(rm -rf .turbo)",
			"Bash(rm *.tmp)",
			"Bash(curl:*)",
			"Read(*)",
			"Write(*)",
			"Edit(*)",
			"MultiEdit(*)",
			"Glob(*)",
			"Grep(*)",
			"LS(*)",
			"TodoWrite(*)",
			"NotebookEdit(*)"
		],
		"deny": [
			"Bash(rm -rf /)",
			"Bash(rm -rf /*)",
			"Bash(rm -rf ~)",
			"Bash(rm -rf ~/*)",
			"Bash(rm -rf ~/.ssh)",
			"Bash(rm -rf ~/.gnupg)",
			"Bash(rm -rf ~/.aws)",
			"Bash(rm -rf $HOME:*)",
			"Bash(rm -rf $HOME/*:*)",
			"Bash(rm -fr /:*)",
			"Bash(rm -fr /*:*)",
			"Bash(rm -fr ~:*)",
			"Bash(rm -fr ~/*:*)",
			"Bash(rm -Rf /:*)",
			"Bash(rm -Rf ~:*)",
			"Read(~/.ssh/*)",
			"Read(~/.aws/*)",
			"Read(~/.gnupg/*)",
			"Read(~/.config/gh/*)",
			"Read(~/.netrc)",
			"Bash(cat ~/.ssh/*)",
			"Bash(cat ~/.aws/*)",
			"Bash(cat ~/.gnupg/*)",
			"Bash(cp ~/.ssh/*:*)",
			"Bash(cp ~/.aws/*:*)",
			"Bash(cp ~/.gnupg/*:*)",
			"Bash(mv ~/.ssh/*:*)",
			"Bash(mv ~/.aws/*:*)",
			"Bash(mv ~/.gnupg/*:*)",
			"Write(~/.ssh/*)",
			"Write(~/.aws/*)",
			"Write(~/.gnupg/*)",
			"Bash(git push --force:*)",
			"Bash(git push -f:*)",
			"Bash(git reset --hard:*)",
			"Bash(git clean -f:*)",
			"Bash(git checkout -- .:*)",
			"Bash(git checkout -- *)",
			"Bash(git stash drop:*)",
			"Bash(git stash clear:*)",
			"Bash(git restore .:*)",
			"Bash(git restore --staged .:*)",
			"Bash(curl * | bash)",
			"Bash(curl * | sh)",
			"Bash(curl * --data:*)",
			"Bash(curl * -d :*)",
			"Bash(curl * -F :*)",
			"Bash(curl * --upload-file:*)",
			"Bash(curl * -T :*)",
			"Bash(wget * | bash)",
			"Bash(wget * | sh)",
			"Bash(sudo:*)",
			"Bash(chmod 777:*)",
			"Bash(find * -delete:*)",
			"Bash(xargs rm:*)",
			"Read(~/.bashrc)",
			"Read(~/.zshrc)",
			"Read(~/.bash_profile)",
			"Read(~/.npmrc)",
			"Read(~/.docker/config.json)",
			"Read(~/.kube/config)",
			"Write(~/.bashrc)",
			"Write(~/.zshrc)",
			"Write(~/.bash_profile)",
			"Write(~/.claude/settings.json)",
			"Write(~/.claude.json)",
			"Bash(gh repo delete:*)",
			"Bash(gh secret:*)",
			"Bash(gh api -X DELETE:*)",
			"Bash(gh api * -X DELETE:*)",
			"Bash(gh release delete:*)",
			"Bash(cat ~/.netrc)",
			"Bash(cat ~/.npmrc)",
			"Bash(cat ~/.docker/config.json)",
			"Bash(cat ~/.kube/config)",
			"Bash(cat ~/.config/gh/*)",
			"Bash(head ~/.netrc)",
			"Bash(head ~/.npmrc)",
			"Bash(head ~/.docker/config.json)",
			"Bash(head ~/.kube/config)",
			"Bash(head ~/.config/gh/*)",
			"Bash(tail ~/.netrc)",
			"Bash(tail ~/.npmrc)",
			"Bash(tail ~/.docker/config.json)",
			"Bash(tail ~/.kube/config)",
			"Bash(tail ~/.config/gh/*)",
			"Bash(cp ~/.netrc:*)",
			"Bash(cp ~/.npmrc:*)",
			"Bash(cp ~/.docker/config.json:*)",
			"Bash(cp ~/.kube/config:*)",
			"Bash(cp ~/.config/gh/*:*)",
			"Bash(mv ~/.netrc:*)",
			"Bash(mv ~/.npmrc:*)",
			"Bash(mv ~/.docker/config.json:*)",
			"Bash(mv ~/.kube/config:*)",
			"Bash(mv ~/.config/gh/*:*)",
			"Bash(curl * --json:*)",
			"Bash(curl * --data-raw:*)",
			"Bash(curl * --data-binary:*)",
			"Bash(curl * --data-urlencode:*)",
			"Bash(curl -X POST:*)",
			"Bash(curl * -X POST:*)",
			"Bash(curl -X PUT:*)",
			"Bash(curl * -X PUT:*)",
			"Bash(awk * system\\(:*)",
			"Bash(awk * system \\(:*)"
		]
	},
	"hooks": {
		"UserPromptSubmit": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bun \"$HOME/.claude/src/hooks/skill-activation.ts\" \"$PROMPT\""
					}
				]
			},
			{
				"hooks": [
					{
						"type": "command",
						"command": "bun \"$HOME/.claude/src/scripts/detect-correction.ts\""
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "bun \"$HOME/.claude/src/hooks/safety-net.ts\""
					}
				]
			},
			{
				"if": "Bash(git commit*)",
				"hooks": [
					{
						"type": "command",
						"command": "bun \"$HOME/.claude/src/scripts/pre-commit-tsc.ts\""
					}
				]
			},
			{
				"if": "Bash(bun add*) Bash(bun install*) Bash(npm install*) Bash(bunx*)",
				"hooks": [
					{
						"type": "command",
						"command": "bun \"$HOME/.claude/src/scripts/check-docs-before-install.ts\""
					}
				]
			},
			{
				"matcher": "Edit",
				"hooks": [
					{
						"type": "command",
						"command": "bun \"$HOME/.claude/src/hooks/pre-edit-validate.ts\""
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "bun \"$HOME/.claude/src/scripts/post-edit.ts\""
					}
				]
			},
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "bun \"$HOME/.claude/src/scripts/post-edit-tsc.ts\"",
						"async": true
					}
				]
			},
			{
				"matcher": "mcp__tldr",
				"hooks": [
					{
						"type": "command",
						"command": "bun \"$HOME/.claude/src/scripts/track-tldr.ts\" \"$TOOL_NAME\"",
						"async": true,
						"timeout": 10
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "bun \"$HOME/.claude/src/scripts/log-bash.ts\"",
						"async": true,
						"timeout": 10
					}
				]
			}
		],
		"PostCompact": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bun \"$HOME/.claude/src/scripts/post-compact.ts\""
					}
				]
			}
		],
		"StopFailure": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bun \"$HOME/.claude/src/scripts/stop-failure.ts\""
					}
				]
			}
		],
		"PreCompact": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bun \"$HOME/.claude/src/scripts/handoff.ts\" create"
					}
				]
			}
		],
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bun \"$HOME/.claude/src/scripts/session-start.ts\""
					}
				]
			}
		],
		"SessionEnd": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bun \"$HOME/.claude/src/scripts/tldr-stats.ts\"; bun \"$HOME/.claude/src/scripts/handoff.ts\" create",
						"async": true,
						"timeout": 30
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bun \"$HOME/.claude/src/scripts/stop-summary.ts\""
					}
				]
			}
		],
		"PostToolUseFailure": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bun \"$HOME/.claude/src/scripts/post-failure.ts\"",
						"async": false,
						"timeout": 10
					}
				]
			}
		],
		"SubagentStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bun \"$HOME/.claude/src/scripts/swarm-log.ts\" start",
						"async": true,
						"timeout": 5
					}
				]
			}
		],
		"SubagentStop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bun \"$HOME/.claude/src/scripts/swarm-log.ts\" stop",
						"async": true,
						"timeout": 5
					}
				]
			}
		],
		"Notification": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bun \"$HOME/.claude/src/scripts/notify.ts\"",
						"async": true,
						"timeout": 10
					}
				]
			}
		],
		"TaskCreated": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bun \"$HOME/.claude/src/scripts/swarm-log.ts\" task",
						"async": true,
						"timeout": 5
					}
				]
			}
		]
	}
}
