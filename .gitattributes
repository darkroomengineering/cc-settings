* text=auto eol=lf

# Source — always LF so shell scripts never break on Windows checkouts.
*.ts  eol=lf
*.tsx eol=lf
*.js  eol=lf
*.mjs eol=lf
*.cjs eol=lf
*.json eol=lf
*.md  eol=lf
*.yml eol=lf
*.yaml eol=lf
*.sh  eol=lf

# Windows-native — must be CRLF or they fail to execute.
*.ps1 eol=crlf
*.cmd eol=crlf
*.bat eol=crlf

# Binary (no diff/merge noise).
*.png binary
*.jpg binary
*.ico binary
*.pdf binary

# Keep lockfiles as LF.
bun.lock  eol=lf
bun.lockb binary
